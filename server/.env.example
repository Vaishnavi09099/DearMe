# =============================================
# DIGITAL PRODUCTIVITY DIARY — SERVER CONFIG
# =============================================

# MongoDB Atlas URI
# Get this from: https://cloud.mongodb.com
# Format: mongodb+srv://<username>:<password>@cluster0.xxxxx.mongodb.net/productivity-diary
MONGO_URI=mongodb+srv://YOUR_USERNAME:YOUR_PASSWORD@cluster0.xxxxx.mongodb.net/productivity-diary

# JWT Secret — make this a long random string (at least 32 chars)
JWT_SECRET=your_super_secret_jwt_key_change_this_in_production_12345

# JWT Expiry
JWT_EXPIRE=7d

# Server Port
PORT=5000

# Client URL (for CORS)
CLIENT_URL=http://localhost:5173
